{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Host Stack (API + Workers)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "app.host_stack"
      ]
    },
    {
      "label": "Start API Only",
      "type": "shell",
      "command": "python",
      "args": [
        "app.py"
      ]
    },
    {
      "label": "Start Entry Worker",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "workers.recognition_worker"
      ],
      "options": {
        "env": {
          "WORKER_ROLE": "entry",
          "WORKER_STATION_ID": "entry-station-1",
          "WORKER_CAMERA_ID": "1",
          "WORKER_CCTV_STREAM_SOURCE": "0"
        }
      }
    },
    {
      "label": "Start Exit Worker",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "workers.recognition_worker"
      ],
      "options": {
        "env": {
          "WORKER_ROLE": "exit",
          "WORKER_STATION_ID": "exit-station-1",
          "WORKER_CAMERA_ID": "2",
          "WORKER_CCTV_STREAM_SOURCE": "1"
        }
      }
    }
  ]
}
